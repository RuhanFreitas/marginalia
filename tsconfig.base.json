{
    "ignoreDeprecations": "6.0",

    "compilerOptions": {
        "types": ["node"],

        "target": "ES2022",
        "module": "commonjs",

        "strict": true,
        "strictPropertyInitialization": false,
        "skipLibCheck": true,

        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
    }
}
