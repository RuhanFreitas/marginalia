# Copy to .env on the Droplet before: docker compose -f compose.prod.yml up -d --build

DB_USER=admin
DB_PASSWORD=change_me_strong_password
DB_NAME=marginalia

JWT_SECRET=change_me_long_random_secret

# Public site URL (used for CORS when the browser origin differs from /api)
CORS_ORIGIN=https://your-domain.com

# API path prefix exposed by nginx (browser + build-time)
NEXT_PUBLIC_API_URL=/api

# Set at runtime in compose.prod.yml for Next.js SSR (do not change unless you rename the server service)
# API_INTERNAL_URL=http://nginx/api

# Set to false only for temporary HTTP testing without TLS
COOKIE_SECURE=true
